# Maintainer: Chimo <chimo@chromic.org>
# NOTE: Opt Deps:
# 	   - nginx
#	   - php7-fpm
pkgname="weather"
pkgver="0.0.1_git20211223"
_gitver="436ab9f21bb4354cebd36c79dde18f3d2f371451"
pkgrel=0
pkgdesc="Weather endpoint for Environment Canada data"
url="https://github.com/chimo/weather"
arch="noarch"
license="AGPL"
depends="
	php7
	php7-json
	php7-mbstring
	php7-openssl
	php7-pdo
	php7-pdo_pgsql
	php7-simplexml
	postgresql
	postgis
"
makedepends="composer"
options="!check"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/chimo/weather/archive/$_gitver.tar.gz
"
builddir="$srcdir/weather-$_gitver"

build() {
	cd "$builddir/private"
	composer install
}

package() {
	installdir="$pkgdir/usr/share/webapps"
	mkdir -p "$installdir"
	cp -r "$srcdir/weather-$_gitver" "$installdir"/"$pkgname"
}

sha512sums="a63b259f737d6d17573843128230d98bdc8c6f26736d1c096185722794f6a56cdb5bf16fafdb0d5c71f6026beeb62fc6ab2bd667f86842c7597124c5e29ff642  weather-0.0.1_git20211223.tar.gz"
