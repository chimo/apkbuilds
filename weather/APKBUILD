# Maintainer: Chimo <chimo@chromic.org>
# NOTE: Opt Deps:
# 	   - nginx
#	   - php81-fpm
#	   - postgresql
#	   - postgis
pkgname="weather"
pkgver="0.0.1_git20230812"
_gitver="3a41c5a94f58ddbf2f286ee613d23809b70fc523"
pkgrel=2
pkgdesc="Weather endpoint for Environment Canada data"
url="https://github.com/chimo/weather"
arch="noarch"
license="AGPL"
depends="
	php81
	php81-json
	php81-mbstring
	php81-openssl
	php81-pdo
	php81-pdo_pgsql
	php81-simplexml
"
makedepends="composer"
options="!check"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/chimo/weather/archive/$_gitver.tar.gz
"
builddir="$srcdir/weather-$_gitver"

build() {
	cd "$builddir/private"
	composer install
}

package() {
	installdir="$pkgdir/usr/share/webapps"
	mkdir -p "$installdir"
	cp -r "$srcdir/weather-$_gitver" "$installdir"/"$pkgname"
}

sha512sums="
ca04fe85a7933f15ce199b73e69ae069b5ed08410cadd02e575d554a857ef2055dbcacf1dca016ab5353f57d6576b0b2c68cf78242c58af2de4b372b06fbfc0a  weather-0.0.1_git20230812.tar.gz
"
