# Maintainer: Alan Lacerda <alacerda@alpinelinux.org>

# Modifications: chimo <chimo@chromic.org>
# Yet-to-be-released version which supports logging to syslog

pkgname=darkhttpd
pkgver="1.14_git20220922"
_gitver="a981031e6f4dd8aa81f0afab387dcca3622c66e0"
pkgrel=0
pkgdesc="A simple, single-threaded, static content webserver"
url="https://unix4lyfe.org/darkhttpd/"
arch="all"
license="ISC"
options="!check" # no tests
install="$pkgname.pre-install"
subpackages="$pkgname-openrc"
source="darkhttpd-$pkgver.tar.gz::https://github.com/emikulic/darkhttpd/archive/$_gitver.tar.gz
	darkhttpd.logrotate
	darkhttpd.initd
	darkhttpd.confd
	darkhttpd-syslog.patch
	"

builddir="$srcdir/$pkgname-$_gitver"

build() {
	make
}

package() {
	install -Dm755 darkhttpd "$pkgdir"/usr/bin/darkhttpd
	install -d "$pkgdir"/var/www/localhost/htdocs \
		"$pkgdir"/var/log/darkhttpd

	install -Dm755 "$srcdir"/darkhttpd.initd "$pkgdir"/etc/init.d/darkhttpd
	install -Dm644 "$srcdir"/darkhttpd.confd "$pkgdir"/etc/conf.d/darkhttpd
}

