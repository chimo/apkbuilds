# Maintainer: Chimo <chimo@chromic.org>
#
# Optional deps:
#	- nginx
#	- php7-fpm
#	- php7-pdo_mysql
#	- mariadb
#
pkgname="freshrss"
_pkgname="FreshRSS"
pkgver=1.18.1
pkgrel=0
pkgdesc="A free, self-hostable aggregator"
url="https://grocy.info/"
arch="noarch"
license="MIT"
depends="
	php7
	php7-ctype
	php7-curl
	php7-dom
	php7-fileinfo
	php7-iconv
	php7-json
	php7-mbstring
	php7-session
	php7-xml
	php7-zip
"
makedepends=""
options="!check"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/FreshRSS/FreshRSS/archive/$pkgver.tar.gz
"

builddir="$srcdir/$_pkgname-$pkgver"

package() {
	installdir="$pkgdir/usr/share/webapps"
	mkdir -p "$installdir"
	cp -r "$builddir" "$installdir"/"$_pkgname"
	chown -R nobody:nobody "$installdir"/"$_pkgname"/data
}

sha512sums="4bd7d7644276bca38b64e25ee8696abd5b48ddb7d0c66e028f5368914f61a54062498d7eb19b45d25e2c9ebaaf0d74cf7e5309bb262d572334cf6a8f782bcce9  freshrss-1.18.1.tar.gz"
