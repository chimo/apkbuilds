# Maintainer: Chimo <chimo@chromic.org>
#
# Optional deps:
#	- nginx
#	- php7-fpm
#	- php7-pdo_pgsql
#	- postgresql14
#
pkgname="freshrss"
_pkgname="FreshRSS"
pkgver=1.20.2
pkgrel=0
pkgdesc="A free, self-hostable aggregator"
url="https://grocy.info/"
arch="noarch"
license="MIT"
depends="
	php8
	php8-ctype
	php8-curl
	php8-dom
	php8-fileinfo
	php8-iconv
	php8-json
	php8-mbstring
	php8-session
	php8-simplexml
	php8-xml
	php8-zip
"
makedepends=""
options="!check"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/FreshRSS/FreshRSS/archive/$pkgver.tar.gz
"

builddir="$srcdir/$_pkgname-$pkgver"

package() {
	installdir="$pkgdir/usr/share/webapps"
	mkdir -p "$installdir"
	cp -r "$builddir" "$installdir"/"$_pkgname"
	chown -R nobody:nobody "$installdir"/"$_pkgname"/data
}

sha512sums="
87437ab7d275c4911e58d16136431749b8e090a00ab73115239d79e32043357d36c0415bb3936268a68ec94df3fbd28596d95153b57c37bccb3867010a9ae73a  freshrss-1.20.2.tar.gz
"
