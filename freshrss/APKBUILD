# Maintainer: Chimo <chimo@chromic.org>
#
# Optional deps:
#	- nginx
#	- php7-fpm
#	- php7-pdo_pgsql
#	- postgresql14
#
pkgname="freshrss"
_pkgname="FreshRSS"
pkgver=1.22.0
pkgrel=0
pkgdesc="A free, self-hostable aggregator"
url="https://grocy.info/"
arch="noarch"
license="MIT"
depends="
	php81
	php81-ctype
	php81-curl
	php81-dom
	php81-fileinfo
	php81-iconv
	php81-json
	php81-mbstring
	php81-session
	php81-simplexml
	php81-xml
	php81-zip
"
makedepends=""
options="!check"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/FreshRSS/FreshRSS/archive/$pkgver.tar.gz
"

builddir="$srcdir/$_pkgname-$pkgver"

package() {
	installdir="$pkgdir/usr/share/webapps"
	mkdir -p "$installdir"
	cp -r "$builddir" "$installdir"/"$_pkgname"
	chown -R nobody:nobody "$installdir"/"$_pkgname"/data
}

sha512sums="
4f462a7b7c28beba0dc6a6ea36dc9ad60b4b95d31710ffb593ce3072b4772f1faf911e942ca9474991b30bba227a8dcf9f945935713e2de7226b53a93a4ec6c5  freshrss-1.22.0.tar.gz
"
