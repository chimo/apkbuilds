# Maintainer: Chimo <chimo@chromic.org>
#
# Optional deps:
#	- nginx
#	- php7-fpm
#	- php7-pdo_pgsql
#	- postgresql14
#
pkgname="freshrss"
_pkgname="FreshRSS"
pkgver=1.20.0
pkgrel=0
pkgdesc="A free, self-hostable aggregator"
url="https://grocy.info/"
arch="noarch"
license="MIT"
depends="
	php8
	php8-ctype
	php8-curl
	php8-dom
	php8-fileinfo
	php8-iconv
	php8-json
	php8-mbstring
	php8-session
	php8-simplexml
	php8-xml
	php8-zip
"
makedepends=""
options="!check"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/FreshRSS/FreshRSS/archive/$pkgver.tar.gz
"

builddir="$srcdir/$_pkgname-$pkgver"

package() {
	installdir="$pkgdir/usr/share/webapps"
	mkdir -p "$installdir"
	cp -r "$builddir" "$installdir"/"$_pkgname"
	chown -R nobody:nobody "$installdir"/"$_pkgname"/data
}

sha512sums="
335bc471950ac150ee3e1a56504ce6111c29497ec1bc5d5eb44b263a8b8aadb701c20ad56578caacc4493ce70dfd8c6f88ff0cec87a9542d444b6a0648fe8561  freshrss-1.20.0.tar.gz
"
