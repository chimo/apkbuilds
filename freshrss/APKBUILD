# Maintainer: Chimo <chimo@chromic.org>

pkgname="freshrss"
_pkgname="FreshRSS"
pkgver=1.22.1
pkgrel=0
pkgdesc="A free, self-hostable aggregator"
url="https://freshrss.org/"
arch="noarch"
license="MIT"
_php="php81"
_php_mods="
    -ctype
    -curl
    -dom
    -fileinfo
    -iconv
    -json
    -mbstring
    -session
    -simplexml
    -xml
    -zip
"
depends="
    $_php
    ${_php_mods//-/$_php-}
"
makedepends=""
options="!check"
source="
    $pkgname-$pkgver.tar.gz::https://github.com/FreshRSS/FreshRSS/archive/$pkgver.tar.gz
"

builddir="$srcdir/$_pkgname-$pkgver"

package() {
    installdir="$pkgdir/usr/share/webapps"
    mkdir -p "$installdir"
    cp -r "$builddir" "$installdir"/"$_pkgname"
    chown -R nobody:nobody "$installdir"/"$_pkgname"/data
}

sha512sums="
5ec4f0483b6ada3c0ee791d3efffd23140417bb643367cc30e309d5294031c3f6289b13f7dae400ded0ad4153233e0f87b7c1f0ba5e7a04a3231a0a865bc5ae6  freshrss-1.22.1.tar.gz
"
