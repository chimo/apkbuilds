# Maintainer: Chimo <chimo@chromic.org>
#
# Optional deps:
#	- nginx
#	- php7-fpm
#	- php7-pdo_pgsql
#	- postgresql14
#
pkgname="freshrss"
_pkgname="FreshRSS"
pkgver=1.21.0
pkgrel=0
pkgdesc="A free, self-hostable aggregator"
url="https://grocy.info/"
arch="noarch"
license="MIT"
depends="
	php81
	php81-ctype
	php81-curl
	php81-dom
	php81-fileinfo
	php81-iconv
	php81-json
	php81-mbstring
	php81-session
	php81-simplexml
	php81-xml
	php81-zip
"
makedepends=""
options="!check"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/FreshRSS/FreshRSS/archive/$pkgver.tar.gz
"

builddir="$srcdir/$_pkgname-$pkgver"

package() {
	installdir="$pkgdir/usr/share/webapps"
	mkdir -p "$installdir"
	cp -r "$builddir" "$installdir"/"$_pkgname"
	chown -R nobody:nobody "$installdir"/"$_pkgname"/data
}

sha512sums="
a36fd73367c12deb67bdc3b4d79ac53607528e9acc06f08909eb14a5134f63b0050f7fc0099b17707dbb8b5f1d9c757a28ed1c4a6b762c27a3391696ce45f7b4  freshrss-1.21.0.tar.gz
"
